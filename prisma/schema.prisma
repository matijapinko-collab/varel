  tenantId  String
  userId    String
  role      HvacRole @default(OWNER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant HvacTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   HvacUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("hvac_tenant_users")
}

model HvacTechnician {
  id              String             @id @default(cuid())
  tenantId        String
  userId          String?
  name            String
  phone           String?
  email           String?
  photoUrl        String?
  employmentType  HvacEmploymentType @default(EMPLOYEE)
  specialization  String?
