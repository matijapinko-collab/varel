  unit       HvacUnit?       @relation(fields: [unitId], references: [id], onDelete: SetNull)
  service    HvacService?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  technician HvacTechnician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  @@index([tenantId, startAt])
  @@index([tenantId, technicianId, startAt])
  @@index([customerId])
  @@map("hvac_appointments")
}

model HvacWorkOrder {
  id               String              @id @default(cuid())
  tenantId         String
  number           String
  customerId       String
  locationId       String?
  unitId           String?
  appointmentId    String?
  serviceId        String?
  technicianId     String?
  status           HvacWorkOrderStatus @default(DRAFT)
  priority         HvacPriority        @default(NORMAL)
  issueDescription String?             @db.Text
  workPerformed    String?             @db.Text
  technicianNotes  String?             @db.Text
  customerNotes    String?             @db.Text
  arrivalAt        DateTime?
  startAt          DateTime?
  completedAt      DateTime?
  laborMinutes     Int?
  recommendation   String?             @db.Text
  nextServiceDate  DateTime?
  paymentMethod    HvacPaymentMethod?
  paymentStatus    HvacInvoiceStatus?
  subtotalEur      Decimal?            @db.Decimal(10, 2)
  vatEur           Decimal?            @db.Decimal(10, 2)
  totalEur         Decimal?            @db.Decimal(10, 2)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
