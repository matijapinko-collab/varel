  valueJson   Json?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model BrandingSetting {
  id                String    @id @default(cuid())
  siteName          String    @default("Varel")
  tagline           String?
  lightLogoId       String?
  darkLogoId        String?
  faviconId         String?
  appIconId         String?
  defaultOgImageId  String?
  primaryColor      String    @default("#2563EB")
  accentColor       String    @default("#0EA5E9")
  defaultTheme      ThemeMode @default(LIGHT)
