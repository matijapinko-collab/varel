model HvacAppointment {
  id                 String                @id @default(cuid())
  tenantId           String
  customerId         String
  locationId         String?
  unitId             String?
  serviceId          String?
  technicianId       String?
  startAt            DateTime
  endAt              DateTime
  estimatedDurationMin Int?
  status             HvacAppointmentStatus @default(WAITING_CONFIRMATION)
  priority           HvacPriority          @default(NORMAL)
  source             HvacSource            @default(MANUAL)
  problemDescription String?               @db.Text
