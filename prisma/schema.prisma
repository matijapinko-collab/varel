// ---------------- Candidates ----------------

model BisneysCandidate {
  id            String                 @id @default(cuid())
  personId      String                 @unique
  status        BisneysCandidateStatus @default(NEW)
  source        String?
  seniority     String?
  yearsExperience Int?
  education     String?
  certifications String?
  licenses      String?
  drivingLicense String?
  ownVehicle    Boolean?
  availability  String?
  expectedSalary String?
  currency      String?                @default("EUR")
  willingToRelocate Boolean?
  willingFieldWork  Boolean?
  currentEmployer   String?
  currentPosition   String?
  rating        Int?
  interviewResult String?
  notes         String?
  // --- CandidateProfile (Faza 2, structured; legacy fields above kept) ---
  profileStatus        BisneysCandidateProfileStatus @default(ACTIVE)
  candidateSource      BisneysCandidateSource?
  recruiterId          String?
  primaryProfessionId  String?
  primaryDisciplineId  String?
  educationLevel       BisneysEducationLevel?
  totalExperienceMonths Int?
  availabilityStatus   BisneysAvailabilityStatus?
  availableFrom        DateTime?
  noticePeriodDays     Int?
  relocationPreference BisneysRelocationPreference?
  // Field work / conditions (brief §12)
  fieldWorkWilling     Boolean @default(false)
  fieldWorkMaxDays     Int?
  internationalField   Boolean @default(false)
  multiDayField        Boolean @default(false)
  worksSaturdays       Boolean @default(false)
  worksSundays         Boolean @default(false)
  shiftWork            Boolean @default(false)
  nightWork            Boolean @default(false)
  heightWork           Boolean @default(false)
  physicalWork         Boolean @default(false)
  // Salary (brief §13)
  expectedSalaryMin    Decimal? @db.Decimal(12, 2)
  expectedSalaryMax    Decimal? @db.Decimal(12, 2)
  minSalary            Decimal? @db.Decimal(12, 2)
  salaryCurrency       String?  @default("EUR")
  salaryIncludesField  Boolean?
  salaryNegotiable     Boolean?
  currentEmployerId    String?
  candidateScore       Decimal? @db.Decimal(5, 2)
  completenessScore    Decimal? @db.Decimal(5, 2)
  // Privacy / retention (brief §38)
  privacyStatus        String?
  legalBasis           String?
  consentReceivedAt    DateTime?
  consentSource        String?
  retentionUntil       DateTime?
  doNotContact         Boolean  @default(false)
  deletionRequestedAt  DateTime?
  anonymizedAt         DateTime?
  firstContactAt DateTime?
  lastActivityAt DateTime?
  nextFollowUpAt DateTime?
  enteredAt     DateTime?
  // Trello linkage
  externalId    String?
  externalSource String?
  lastSyncedAt  DateTime?
  syncStatus    BisneysSyncStatus?
  rawData       Json?
  possibleDuplicate Boolean            @default(false)
  tags          String[]               @default([])
  deletedAt     DateTime?
  deletedById   String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  person         BisneysPerson                   @relation(fields: [personId], references: [id])
  statusHistory  BisneysCandidateStatusHistory[]
  professions    BisneysCandidateProfession[]
  candidateJobs  BisneysCandidateJob[]
  employments    BisneysCandidateEmployment[]
  languages      BisneysCandidateLanguage[]
  skills         BisneysCandidateSkill[]
  certificationRecords BisneysCandidateCertification[]
  educationRecords BisneysEducationRecord[]
  drivingLicenses  BisneysCandidateDrivingLicense[]
  preference     BisneysCandidatePreference?
  applications   BisneysCandidateApplication[]
  contactAttempts BisneysContactAttempt[]
  interviews     BisneysInterview[]
  assessments    BisneysCandidateAssessment[]
  poolMemberships BisneysTalentPoolMember[]
  companyLinks   BisneysCandidateCompanyLink[]

  @@index([status])
  @@index([profileStatus])
  @@index([recruiterId])
  @@index([primaryProfessionId])
  @@index([externalId])
  @@map("bisneys_candidates")
}

model BisneysCandidateStatusHistory {
  id          String   @id @default(cuid())
  candidateId String
  fromStatus  String?
  toStatus    String
  changedById String?
  jobId       String?
