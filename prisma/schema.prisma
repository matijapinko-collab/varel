  oib             String?
  website         String?
  industry        String?
  size            String?
  country         String?
  city            String?
  address         String?
  phone           String?
  email           String?
  description     String?
  status          BisneysSalesStatus @default(NEW_COMPANY)
  pipelineStageId String?
  ownerId         String?
  leadSource      String?
  dealValue       Decimal?           @db.Decimal(12, 2)
  currency        String?            @default("EUR")
  expectedCloseDate DateTime?
  closeProbability  Int?
  serviceId         String?
  lastActivityAt    DateTime?
  nextFollowUpAt    DateTime?
  externalId        String?
  externalSource    String?
  lastSyncedAt      DateTime?
  syncStatus        BisneysSyncStatus?
  rawData           Json?
  createdById       String?
  deletedAt         DateTime?
  deletedById       String?
