// =============================================================
// VAREL — Prisma schema
// Generated from the approved "Varel Database Design" document.
// Tables are snake_case in the database via @@map; models are
// PascalCase per the naming guidelines in that document.
// =============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------
// Enums
// -----------------------------------------------------------------

enum UserRoleType {
  OWNER
  ADMIN
  EDITOR
  WRITER
  TRANSLATOR
  AFFILIATE_MANAGER
  SEO_MANAGER
  VIEWER
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

enum ContentOrigin {
  HUMAN_WRITTEN
  AI_ASSISTED
  AI_GENERATED
}

enum ArticleType {
  CORNERSTONE
  STANDARD
}

enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
}

enum PricingModel {
  FREE
  FREEMIUM
  PAID
  TRIAL
  OPEN_SOURCE
  CUSTOM
}

enum AffiliateNetwork {
  PARTNERSTACK
  IMPACT
  AWIN
  CJ_AFFILIATE
  AMAZON_ASSOCIATES
  REWARDFUL
  FIRSTPROMOTER
  DIRECT
  OTHER
}

enum AffiliateStatus {
  ACTIVE
  INACTIVE
  PENDING
  EXPIRED
}

enum AnalyticsEventType {
  PAGE_VIEW
  TOOL_VIEW
  AFFILIATE_CLICK
  SEARCH
  LANGUAGE_SWITCH
  PROMPT_COPY
  COMPARISON_VIEW
  CATEGORY_CLICK
  NEWSLETTER_SIGNUP
  OUTBOUND_CLICK
  DEAL_CLICK
}

enum SeoEntityType {
  PAGE
  TOOL
  CATEGORY
  ARTICLE
  EDITORIAL
  NEWS
  PROMPT
  DEAL
  COMPARISON
}

enum AffiliateEntityType {
  TOOL
  DEAL
  AMAZON_PRODUCT
  CUSTOM
}

enum NewsPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PromptDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
}

enum MenuLocation {
  HEADER
  FOOTER
  SECONDARY
}

enum AuditAction {
  LOGIN
  FAILED_LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  SEO_UPDATE
  AFFILIATE_UPDATE
  SETTINGS_UPDATE
  ROLE_CHANGE
  MEDIA_UPLOAD
  MEDIA_DELETE
  TRANSLATION_GENERATED
  TRANSLATION_PUBLISHED
  VERSION_UPDATE
  ROLLBACK
  BACKUP_CREATED
}

enum VersionStatus {
  DRAFT
  READY
  APPLIED
  ROLLED_BACK
  FAILED
}

enum BackupType {
  MANUAL
  SCHEDULED
  PRE_UPDATE
}

enum BackupStatus {
  PENDING
  COMPLETED
  FAILED
}

// -----------------------------------------------------------------
// Core system: users, roles, permissions
// -----------------------------------------------------------------

model User {
  id               String    @id @default(cuid())
  name             String
  username         String    @unique
  email            String    @unique
  passwordHash     String
  image            String?
  bio              String?   @db.Text
  roleId           String
  isActive         Boolean   @default(true)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  role             Role            @relation(fields: [roleId], references: [id])
  auditLogs        AuditLog[]
  articles         Article[]       @relation("ArticleAuthor")
  reviewedArticles Article[]       @relation("ArticleReviewer")
  editorialPosts   EditorialPost[]
  media            Media[]
  pagesCreated     Page[]          @relation("PageCreatedBy")
  newsItems        NewsItem[]
  comparisons      Comparison[]
  prompts          Prompt[]
  appVersions      AppVersion[]
  backups          Backup[]
  globalSections   GlobalSection[]

  @@map("users")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  type        UserRoleType @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// -----------------------------------------------------------------
// Languages
// -----------------------------------------------------------------

model Language {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  nativeName String
  isDefault  Boolean  @default(false)
  isEnabled  Boolean  @default(true)
  direction  String   @default("ltr")
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pages                      Page[]
  toolTranslations           ToolTranslation[]
  categoryTranslations       CategoryTranslation[]
  articleTranslations        ArticleTranslation[]
  editorialTranslations      EditorialTranslation[]
  newsTranslations           NewsTranslation[]
  comparisonTranslations     ComparisonTranslation[]
  promptTranslations         PromptTranslation[]
  promptCategoryTranslations PromptCategoryTranslation[]
  dealTranslations           DealTranslation[]
  seoMetadata                SeoMetadata[]
  menus                      Menu[]
  subscribers                NewsletterSubscriber[]

  @@map("languages")
}

// -----------------------------------------------------------------
// Page builder / CMS
// -----------------------------------------------------------------

model Page {
  id             String        @id @default(cuid())
  languageId     String
  parentPageId   String?
  // Groups translated variants of the same logical page (variants share one translationKey)
  translationKey String        @default(cuid())
  title          String
  slug           String
  fullPath       String?
  template       String        @default("default")
  status         ContentStatus @default(DRAFT)
  isHomepage     Boolean       @default(false)
  contentOrigin  ContentOrigin @default(HUMAN_WRITTEN)
  publishedAt    DateTime?
  scheduledAt    DateTime?
  createdById    String?
  updatedById    String?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  language   Language    @relation(fields: [languageId], references: [id])
  parentPage Page?       @relation("PageHierarchy", fields: [parentPageId], references: [id])
  childPages Page[]      @relation("PageHierarchy")
  createdBy  User?       @relation("PageCreatedBy", fields: [createdById], references: [id])
  blocks     PageBlock[]

  @@unique([languageId, slug])
  @@index([status])
  @@index([translationKey])
  @@map("pages")
}

model PageBlock {
  id              String   @id @default(cuid())
  pageId          String?
  globalSectionId String?
  parentBlockId   String?
  type            String
  position        Int      @default(0)
  settingsJson    Json?
  contentJson     Json?
  responsiveJson  Json?
  isHidden        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  page          Page?          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  globalSection GlobalSection? @relation(fields: [globalSectionId], references: [id], onDelete: Cascade)
  parentBlock   PageBlock?     @relation("BlockHierarchy", fields: [parentBlockId], references: [id])
  childBlocks   PageBlock[]    @relation("BlockHierarchy")

  @@index([pageId, position])
  @@map("page_blocks")
}

model GlobalSection {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  type         String   @default("section")
  settingsJson Json?
  contentJson  Json?
  isActive     Boolean  @default(true)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy User?       @relation(fields: [createdById], references: [id])
  blocks    PageBlock[]

  @@map("global_sections")
}

// -----------------------------------------------------------------
// Media library
// -----------------------------------------------------------------

model Media {
  id               String    @id @default(cuid())
  filename         String
  originalFilename String
  mimeType         String
  size             Int
  width            Int?
  height           Int?
  url              String
  storageKey       String
  altText          String?
  caption          String?
  title            String?
  folderId         String?
  uploadedById     String?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  folder     MediaFolder? @relation(fields: [folderId], references: [id])
  uploadedBy User?        @relation(fields: [uploadedById], references: [id])

  toolLogos               Tool[]             @relation("ToolLogo")
  toolScreenshots         ToolScreenshot[]
  categoryFeaturedImages  Category[]         @relation("CategoryFeaturedImage")
  articleFeaturedImages   Article[]          @relation("ArticleFeaturedImage")
  editorialFeaturedImages EditorialPost[]    @relation("EditorialFeaturedImage")
  newsFeaturedImages      NewsItem[]         @relation("NewsFeaturedImage")
  dealImages              Deal[]             @relation("DealImage")
  partnerLogos            AffiliatePartner[] @relation("PartnerLogo")

  @@map("media")
}

model MediaFolder {
  id             String   @id @default(cuid())
  name           String
  parentFolderId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parentFolder MediaFolder?  @relation("FolderHierarchy", fields: [parentFolderId], references: [id])
  childFolders MediaFolder[] @relation("FolderHierarchy")
  media        Media[]

  @@map("media_folders")
}

// -----------------------------------------------------------------
// SEO (polymorphic: one table for every content type)
// -----------------------------------------------------------------

model SeoMetadata {
  id                    String        @id @default(cuid())
  entityType            SeoEntityType
  entityId              String
  languageId            String
  metaTitle             String?
  metaDescription       String?
  focusKeyword          String?
  secondaryKeywordsJson Json?
  canonicalUrl          String?
  ogTitle               String?
  ogDescription         String?
  ogImageId             String?
  twitterTitle          String?
  twitterDescription    String?
  twitterImageId        String?
  robots                String        @default("index,follow")
  schemaType            String?
  schemaJson            Json?
  includeInSitemap      Boolean       @default(true)
  priority              Float         @default(0.7)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  language Language @relation(fields: [languageId], references: [id])

  @@unique([entityType, entityId, languageId])
  @@index([entityType, entityId])
  @@map("seo_metadata")
}

// -----------------------------------------------------------------
// Tool directory
// -----------------------------------------------------------------

model Tool {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  logoId       String?
  websiteUrl   String?
  pricingModel PricingModel  @default(FREEMIUM)
  hasFreeTrial Boolean       @default(false)
  hasApi       Boolean       @default(false)
  isOpenSource Boolean       @default(false)
  isFeatured   Boolean       @default(false)
  isTrending   Boolean       @default(false)
  status       ContentStatus @default(DRAFT)
  editorRating Float?
  userRating   Float?
  createdById  String?
  updatedById  String?
  publishedAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  logo                Media?            @relation("ToolLogo", fields: [logoId], references: [id])
  translations        ToolTranslation[]
  categories          ToolCategory[]
  features            ToolFeature[]
  pricingPlans        ToolPricing[]
  screenshots         ToolScreenshot[]
  alternatives        ToolAlternative[] @relation("ToolAlternatives")
  alternativeOf       ToolAlternative[] @relation("AlternativeTool")
  affiliateLinks      AffiliateLink[]
  articleTools        ArticleTool[]
  comparisonAArticles Article[]         @relation("ComparisonToolA")
  comparisonBArticles Article[]         @relation("ComparisonToolB")
  comparisonTools     ComparisonTool[]
  newsRelations       NewsRelatedTool[]
  offers              ProductOffer[]
  dealsAsProduct      Deal[]            @relation("DealProduct")

  @@index([status])
  @@map("tools")
}

model ToolTranslation {
  id               String        @id @default(cuid())
  toolId           String
  languageId       String
  name             String
  slug             String
  shortDescription String?
  longDescription  String?       @db.Text
  bestFor          String?
  whoShouldUseIt   String?       @db.Text
  whoShouldAvoidIt String?       @db.Text
  prosJson         Json?
  consJson         Json?
  faqJson          Json?
  useCasesJson     Json?
  integrationsJson Json?
  platformsJson    Json?
  status           ContentStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tool     Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id])

  @@unique([toolId, languageId])
  @@index([languageId, slug])
  @@map("tool_translations")
}

model Category {
  id               String        @id @default(cuid())
  parentCategoryId String?
  slug             String        @unique
  icon             String?
  featuredImageId  String?
  isFeatured       Boolean       @default(false)
  position         Int           @default(0)
  status           ContentStatus @default(PUBLISHED)
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  parentCategory  Category?             @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  childCategories Category[]            @relation("CategoryHierarchy")
  featuredImage   Media?                @relation("CategoryFeaturedImage", fields: [featuredImageId], references: [id])
  translations    CategoryTranslation[]
  tools           ToolCategory[]
  primaryArticles Article[]             @relation("ArticlePrimaryCategory")

  @@map("categories")
}

model CategoryTranslation {
  id          String   @id @default(cuid())
  categoryId  String
  languageId  String
  name        String
  slug        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id])

  @@unique([categoryId, languageId])
  @@index([languageId, slug])
  @@map("category_translations")
}

model ToolCategory {
  id         String   @id @default(cuid())
  toolId     String
  categoryId String
  createdAt  DateTime @default(now())

  tool     Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([toolId, categoryId])
  @@map("tool_categories")
}

model ToolFeature {
  id          String   @id @default(cuid())
  toolId      String
  name        String
  description String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@map("tool_features")
}

model ToolPricing {
  id            String   @id @default(cuid())
  toolId        String
  planName      String
  price         Decimal? @db.Decimal(10, 2)
  currency      String   @default("USD")
  billingPeriod String   @default("month")
  featuresJson  Json?
  isPopular     Boolean  @default(false)
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@map("tool_pricing")
}

model ToolScreenshot {
  id        String   @id @default(cuid())
  toolId    String
  mediaId   String
  caption   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  tool  Tool  @relation(fields: [toolId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@map("tool_screenshots")
}

model ToolAlternative {
  id                String   @id @default(cuid())
  toolId            String
  alternativeToolId String
  reason            String?
  position          Int      @default(0)
  createdAt         DateTime @default(now())

  tool            Tool @relation("ToolAlternatives", fields: [toolId], references: [id], onDelete: Cascade)
  alternativeTool Tool @relation("AlternativeTool", fields: [alternativeToolId], references: [id], onDelete: Cascade)

  @@unique([toolId, alternativeToolId])
  @@map("tool_alternatives")
}

// -----------------------------------------------------------------
// Articles (guides)
// -----------------------------------------------------------------

model Article {
  id              String        @id @default(cuid())
  type            ArticleType   @default(STANDARD)
  status          ContentStatus @default(DRAFT)
  contentOrigin   ContentOrigin @default(HUMAN_WRITTEN)
  authorId        String?
  featuredImageId String?
  targetWordCount Int?
  publishedAt     DateTime?
  scheduledAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Standardized post structure (language-independent references + toggles).
  primaryCategoryId        String?
  secondaryCategoryIdsJson Json?
  prosConsEnabled          Boolean   @default(false)
  comparisonEnabled        Boolean   @default(false)
  comparisonToolAId        String?
  comparisonToolBId        String?
  varelVerdictEnabled      Boolean   @default(false)
  reviewerId               String?
  lastReviewedAt           DateTime?

  // Localized public author (byline) + review/pricing freshness dates.
  authorProfileId          String?
  lastTestedAt             DateTime?
  pricingCheckedAt         DateTime?

  authorProfile   Author?                @relation("ArticleAuthorProfile", fields: [authorProfileId], references: [id])
  author          User?                  @relation("ArticleAuthor", fields: [authorId], references: [id])
  reviewer        User?                  @relation("ArticleReviewer", fields: [reviewerId], references: [id])
  featuredImage   Media?                 @relation("ArticleFeaturedImage", fields: [featuredImageId], references: [id])
  primaryCategory Category?              @relation("ArticlePrimaryCategory", fields: [primaryCategoryId], references: [id])
  comparisonToolA Tool?                  @relation("ComparisonToolA", fields: [comparisonToolAId], references: [id])
  comparisonToolB Tool?                  @relation("ComparisonToolB", fields: [comparisonToolBId], references: [id])
  translations    ArticleTranslation[]
  tools           ArticleTool[]
  affiliateLinks  ArticleAffiliateLink[]

  @@index([status])
  @@index([primaryCategoryId])
  @@index([authorProfileId])
  @@map("articles")
}

// -----------------------------------------------------------------
// Varel HVAC — early-access leads captured from the /hvac landing page.
// -----------------------------------------------------------------
model HvacLead {
  id             String        @id @default(cuid())
  fullName       String
  company        String
  email          String
  phone          String?
  teamSize       String?
  city           String?
  currentSystem  String?
  interestedPlan String?
  message        String?       @db.Text
  status         HvacLeadStatus @default(NEW)
  source         String        @default("Varel HVAC")
  sourcePage     String?
  ipHash         String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, createdAt])
  @@map("hvac_leads")
}

enum HvacLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  BETA_CANDIDATE
  NOT_INTERESTED
  CONVERTED
}

// -----------------------------------------------------------------
// Localized author profiles (public byline). Separate from `User`
// (login accounts) — an author is the public identity shown on
// articles/reviews/guides, displayed differently per locale
// (e.g. "Matt Pinko" on /en, "Matija Pinko" on /hr).
// -----------------------------------------------------------------
model Author {
  id           String  @id @default(cuid())
  internalName String

  displayNameEn String
  displayNameHr String
  slugEn        String  @unique
  slugHr        String  @unique

  roleEn String?
  roleHr String?

  bioShortEn String? @db.Text
  bioShortHr String? @db.Text
  bioLongEn  String? @db.Text
  bioLongHr  String? @db.Text

  // Single uploaded photo (URL only — never raw base64). Reused for author
  // box + About page unless a separate About photo is provided.
  photoUrl      String?
  photoAltEn    String?
  photoAltHr    String?
  aboutPhotoUrl String?
  aboutPhotoAltEn String?
  aboutPhotoAltHr String?

  email        String?
  websiteUrl   String?
  linkedinUrl  String?
  xUrl         String?
  instagramUrl String?
  youtubeUrl   String?
  githubUrl    String?

  expertiseTagsEnJson Json?
  expertiseTagsHrJson Json?

  defaultLanguage String  @default("hr")
  isDefault       Boolean @default(false)
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[] @relation("ArticleAuthorProfile")

  @@index([isActive])
  @@map("authors")
}

model ArticleTranslation {
  id                    String        @id @default(cuid())
  articleId             String
  languageId            String
  title                 String
  slug                  String
  excerpt               String?       @db.Text
  body                  String?       @db.Text
  faqJson               Json?
  outlineJson           Json?
  focusKeyword          String?
  secondaryKeywordsJson Json?
  status                ContentStatus @default(DRAFT)

  // Language-dependent structured post content.
  featuredImageAlt       String?
  // Pros / Cons module
  prosConsHeading        String?
  prosConsIntro          String? @db.Text
  prosJson               Json?
  consJson               Json?
  // Comparison box copy
  comparisonHeading      String?
  comparisonSummary      String? @db.Text
  comparisonCtaLabel     String?
  comparisonCtaUrl       String?
  // LLM / AI search optimization
  aiSummary              String? @db.Text
  directAnswer           String? @db.Text
  keyTakeawaysJson       Json?
  bestForJson            Json?
  notIdealForJson        Json?
  mentionedEntityIdsJson Json?
  mentionedEntitiesText  String? @db.Text
  sourceReferencesJson   Json?
  // Varel Verdict box
  varelVerdictHeadline   String?
  varelVerdictSummary    String? @db.Text
  varelVerdictBestFor    String?
  varelVerdictSkipIf     String?
  varelVerdictRating     Float?
  // Completion tracking
  seoCompletionScore     Int?
  llmCompletionScore     Int?
  publishChecklistJson   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article  Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id])

  @@unique([articleId, languageId])
  @@unique([languageId, slug])
  @@map("article_translations")
}

model ArticleTool {
  id        String   @id @default(cuid())
  articleId String
  toolId    String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tool    Tool    @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([articleId, toolId])
  @@map("article_tools")
}

model ArticleAffiliateLink {
  id              String   @id @default(cuid())
  articleId       String
  affiliateLinkId String
  position        Int      @default(0)
  createdAt       DateTime @default(now())

  article       Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  affiliateLink AffiliateLink @relation(fields: [affiliateLinkId], references: [id], onDelete: Cascade)

  @@unique([articleId, affiliateLinkId])
  @@map("article_affiliate_links")
}

// -----------------------------------------------------------------
// Editorial — The Varel Brief
// -----------------------------------------------------------------

model EditorialPost {
  id              String        @id @default(cuid())
  authorId        String
  status          ContentStatus @default(DRAFT)
  contentOrigin   ContentOrigin @default(HUMAN_WRITTEN)
  featuredImageId String?
  publishedAt     DateTime?
  scheduledAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  author        User                   @relation(fields: [authorId], references: [id])
  featuredImage Media?                 @relation("EditorialFeaturedImage", fields: [featuredImageId], references: [id])
  translations  EditorialTranslation[]

  @@index([status])
  @@map("editorial_posts")
}

model EditorialTranslation {
  id              String        @id @default(cuid())
  editorialPostId String
  languageId      String
  title           String
  slug            String
  excerpt         String?       @db.Text
  body            String?       @db.Text
  predictionText  String?       @db.Text
  marketImpact    String?       @db.Text
  category        String?
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  editorialPost EditorialPost @relation(fields: [editorialPostId], references: [id], onDelete: Cascade)
  language      Language      @relation(fields: [languageId], references: [id])

  @@unique([editorialPostId, languageId])
  @@unique([languageId, slug])
  @@map("editorial_translations")
}

// -----------------------------------------------------------------
// News
// -----------------------------------------------------------------

model NewsItem {
  id                String        @id @default(cuid())
  sourceName        String?
  sourceUrl         String?
  sourcePublishedAt DateTime?
  priority          NewsPriority  @default(MEDIUM)
  status            ContentStatus @default(DRAFT)
  featuredImageId   String?
  createdById       String?
  publishedAt       DateTime?
  deletedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  featuredImage Media?            @relation("NewsFeaturedImage", fields: [featuredImageId], references: [id])
  createdBy     User?             @relation(fields: [createdById], references: [id])
  translations  NewsTranslation[]
  relatedTools  NewsRelatedTool[]

  @@index([status])
  @@map("news_items")
}

model NewsTranslation {
  id           String        @id @default(cuid())
  newsItemId   String
  languageId   String
  title        String
  slug         String
  summary      String?       @db.Text
  body         String?       @db.Text
  whyItMatters String?       @db.Text
  status       ContentStatus @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  newsItem NewsItem @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id])

  @@unique([newsItemId, languageId])
  @@unique([languageId, slug])
  @@map("news_translations")
}

model NewsRelatedTool {
  id         String   @id @default(cuid())
  newsItemId String
  toolId     String
  createdAt  DateTime @default(now())

  newsItem NewsItem @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  tool     Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([newsItemId, toolId])
  @@map("news_related_tools")
}

// -----------------------------------------------------------------
