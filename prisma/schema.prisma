  customer   HvacCustomer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  location   HvacLocation?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  unit       HvacUnit?       @relation(fields: [unitId], references: [id], onDelete: SetNull)
