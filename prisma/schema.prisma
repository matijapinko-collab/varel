// ---------------- Relationship engine ----------------

model BisneysRelationshipType {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String?  @unique
  category    String?
  description String?
  symmetric   Boolean  @default(false)
  directed    Boolean  @default(true)
  color       String?
  icon        String?
  isActive    Boolean  @default(true)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  relationships BisneysRelationship[]

  @@map("bisneys_relationship_types")
}

model BisneysRelationship {
  id                 String                       @id @default(cuid())
  sourcePersonId     String
  targetPersonId     String
  relationshipTypeId String
  direction          BisneysRelationshipDirection @default(DIRECTED)
  companyId          String?
  jobId              String?
  startDate          DateTime?
  endDate            DateTime?
  note               String?
  infoSource         String?
  sourceType         String?
  strengthScore      Int?
  confidenceScore    Int?
  confirmed          Boolean                      @default(false)
  addedById          String?
  deletedAt          DateTime?
  deletedById        String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @default(now()) @updatedAt

  source BisneysPerson           @relation("BisneysRelFrom", fields: [sourcePersonId], references: [id])
  target BisneysPerson           @relation("BisneysRelTo", fields: [targetPersonId], references: [id])
  type   BisneysRelationshipType @relation(fields: [relationshipTypeId], references: [id])

  @@index([sourcePersonId])
  @@index([targetPersonId])
  @@index([relationshipTypeId])
  @@index([companyId])
  @@map("bisneys_relationships")
}

// Structured employment history — powers "worked together" suggestions,
// company access paths and the employment cards (brief §17).
model BisneysEmployment {
  id          String    @id @default(cuid())
  personId    String
  companyId   String?
  companyName String?
  title       String?
  department  String?
  startDate   DateTime?
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  source      String?
  confirmed   Boolean   @default(false)
  note        String?
  createdById String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  person  BisneysPerson   @relation(fields: [personId], references: [id])
  company BisneysCompany? @relation(fields: [companyId], references: [id])

  @@index([personId])
  @@index([companyId])
  @@map("bisneys_employments")
}

// Auto-suggested relationships awaiting confirmation (brief §33/§34). Never
// promoted to a real relationship without a human confirm.
model BisneysRelationshipSuggestion {
  id             String    @id @default(cuid())
  sourcePersonId String
  targetPersonId String
  suggestedType  String?
  signalType     String
  reason         String
  confidence     String    @default("MEDIUM")
  companyId      String?
  status         String    @default("PENDING")
  resolvedById   String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@unique([sourcePersonId, targetPersonId, signalType])
  @@index([status])
  @@map("bisneys_relationship_suggestions")
}

model BisneysReferral {
  id                  String   @id @default(cuid())
  referrerPersonId    String
  referredPersonId    String
  companyId           String?
  resultedInInterview Boolean  @default(false)
  resultedInHire      Boolean  @default(false)
  dealValue           Decimal? @db.Decimal(12, 2)
  note                String?
  createdById         String?
  createdAt           DateTime @default(now())

  referrer BisneysPerson @relation("BisneysReferrer", fields: [referrerPersonId], references: [id])
  referred BisneysPerson @relation("BisneysReferred", fields: [referredPersonId], references: [id])

  @@index([referrerPersonId])
  @@index([referredPersonId])
  @@map("bisneys_referrals")
}

