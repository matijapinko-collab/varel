model NewsletterSubscriber {
  id          String           @id @default(cuid())
  email       String           @unique
  languageId  String?
  source      String?
  status      SubscriberStatus @default(PENDING)
  confirmedAt DateTime?
  createdAt   DateTime         @default(now())
