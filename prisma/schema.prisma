model AffiliateLink {
  id                   String              @id @default(cuid())
  brandName            String
  entityType           AffiliateEntityType @default(CUSTOM)
  toolId               String?
  originalUrl          String?
  affiliateUrl         String
  network              AffiliateNetwork    @default(DIRECT)
  commissionType       String?
  commissionValue      String?
  cookieDurationDays   Int?
  allowedCountriesJson Json?
  status               AffiliateStatus     @default(ACTIVE)
  notes                String?             @db.Text
  lastCheckedAt        DateTime?
  deletedAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  tool         Tool?                  @relation(fields: [toolId], references: [id])
  clicks       AffiliateClick[]
  deals        Deal[]
  articleLinks ArticleAffiliateLink[]

  @@index([status])
  @@map("affiliate_links")
}

model AffiliateClick {
  id               String   @id @default(cuid())
  affiliateLinkId  String
  sourceEntityType String?
  sourceEntityId   String?
  languageCode     String?
  country          String?
  device           String?
  referrer         String?
  userAgent        String?
  ipHash           String?
