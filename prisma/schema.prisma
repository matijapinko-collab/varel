// ─────────────────────────── VAREL ELECTRIC · PHASE F ───────────────────────────
// Warehouses, items, immutable stock ledger, consumption with confirmation
// (brief §37–§48). Stock balance is the SUM of movements, never a mutable field.

enum ElectroWarehouseType {
  CENTRAL
  REGIONAL
  MOBILE
  SITE
  TEMPORARY
  RETURNS
  DEFECTIVE
}

enum ElectroStockMovementType {
  OPENING_BALANCE
  RECEIPT
  TRANSFER_OUT
  TRANSFER_IN
  ISSUE_TO_PROJECT
  CONSUMPTION_CONFIRMED
  RETURN_FROM_PROJECT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGE
  LOSS
  WRITE_OFF
  ERP_IMPORT
}

enum ElectroConsumptionStatus {
  DRAFT
  PENDING_CONFIRMATION
  PARTIALLY_CONFIRMED
  CONFIRMED
  REJECTED
  CANCELLED
}

model ElectroWarehouse {
  id           String               @id @default(cuid())
  companyId    String
  code         String
  name         String
  type         ElectroWarehouseType @default(CENTRAL)
  address      String?
  branchId     String?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  company      ElectroCompany     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  movements    ElectroStockMovement[]
  consumptions ElectroMaterialConsumption[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("electro_warehouses")
}

model ElectroItem {
  id            String   @id @default(cuid())
  companyId     String
  sku           String
  externalSku   String?
  name          String
  description   String?
  category      String?
  unit          String   @default("kom")
  barcode       String?
  purchasePrice Decimal? @db.Decimal(12, 4)
  minStock      Decimal? @db.Decimal(14, 3)
  targetStock   Decimal? @db.Decimal(14, 3)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company      ElectroCompany         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  movements    ElectroStockMovement[]
  consumptions ElectroMaterialConsumption[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@map("electro_items")
}

/// The immutable ledger (brief §40). Positive qtyDelta adds to the warehouse,
/// negative removes. Balance = SUM(qtyDelta) per (item, warehouse). Rows are
/// never updated or deleted; corrections are new movements.
model ElectroStockMovement {
  id          String                   @id @default(cuid())
  companyId   String
  itemId      String
  warehouseId String
  type        ElectroStockMovementType
  qtyDelta    Decimal                  @db.Decimal(14, 3)
  unitPrice   Decimal?                 @db.Decimal(12, 4)
  projectId   String?
  reason      String?
  reference   String?
  createdByUserId String?
  createdAt   DateTime                 @default(now())

  company   ElectroCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  item      ElectroItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse ElectroWarehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([companyId, itemId, warehouseId])
  @@map("electro_stock_movements")
}

/// Consumption reported by a worker (brief §41). Not final until confirmed by a
/// site manager; only then does a CONSUMPTION_CONFIRMED movement post.
model ElectroMaterialConsumption {
  id            String                   @id @default(cuid())
  companyId     String
  projectId     String
  itemId        String
  warehouseId   String
  phaseId       String?
  locationId    String?
  quantity      Decimal                  @db.Decimal(14, 3)
  confirmedQuantity Decimal?             @db.Decimal(14, 3)
  status        ElectroConsumptionStatus @default(PENDING_CONFIRMATION)
  comment       String?
  reportedByUserId String?
  confirmedByUserId String?
  confirmedAt   DateTime?
  movementId    String?                  @unique
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  company   ElectroCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project   ElectroProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  item      ElectroItem      @relation(fields: [itemId], references: [id])
  warehouse ElectroWarehouse @relation(fields: [warehouseId], references: [id])

  @@index([companyId, projectId, status])
  @@map("electro_material_consumptions")
}

