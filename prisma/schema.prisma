  @@index([action, createdAt])
  @@map("audit_logs")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipHash    String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("login_attempts")
}

