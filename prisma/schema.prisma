// -----------------------------------------------------------------

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      AuditAction
  entityType  String?
  entityId    String?
  ipHash      String?
  userAgent   String?
  detailsJson Json?
  createdAt   DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipHash    String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("login_attempts")
}

// -----------------------------------------------------------------
// Version manager & backups
// -----------------------------------------------------------------

model AppVersion {
  id          String        @id @default(cuid())
  version     String        @unique
  title       String
  changelog   String?       @db.Text
  status      VersionStatus @default(DRAFT)
  createdById String?
  createdAt   DateTime      @default(now())
  appliedAt   DateTime?

  createdBy User?           @relation(fields: [createdById], references: [id])
  packages  UpdatePackage[]

  @@map("app_versions")
}

model UpdatePackage {
  id               String   @id @default(cuid())
  versionId        String
  codePatch        String?  @db.Text
  migrationPatch   String?  @db.Text
  configPatch      String?  @db.Text
  validationStatus String?
  testStatus       String?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  version AppVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@map("update_packages")
}

model Backup {
  id          String       @id @default(cuid())
  type        BackupType   @default(MANUAL)
  status      BackupStatus @default(PENDING)
  storageUrl  String?
  size        Int?
  notes       String?
  createdById String?
  createdAt   DateTime     @default(now())

  createdBy User? @relation(fields: [createdById], references: [id])

  @@map("backups")
}

// -----------------------------------------------------------------
// Best Deals: affiliate partners, product offers, price history
// -----------------------------------------------------------------

enum PartnerType {
  DIRECT
  NETWORK
  MARKETPLACE
  RETAILER
}

enum OfferAvailability {
  IN_STOCK
  OUT_OF_STOCK
  LIMITED
  PREORDER
  UNKNOWN
}

model AffiliatePartner {
  id                    String      @id @default(cuid())
  name                  String
  slug                  String      @unique
  logoId                String?
  websiteUrl            String?
  affiliateNetwork      String?
  partnerType           PartnerType @default(DIRECT)
  defaultTrackingParams String?
  // Official CSV datafeed URL for automated imports (Phase 3). Fetched by the
  // daily cron and the "Fetch feed now" admin action. Same columns as the
  // manual CSV import.
  feedUrl               String?
  lastFeedFetchAt       DateTime?
  contactEmail          String?
  priority              Int         @default(0)
  isActive              Boolean     @default(true)
  notes                 String?     @db.Text
  deletedAt             DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  logo   Media?         @relation("PartnerLogo", fields: [logoId], references: [id])
  offers ProductOffer[]
  deals  Deal[]

  @@map("affiliate_partners")
}

model ProductOffer {
  id                String            @id @default(cuid())
  toolId            String
  partnerId         String
  merchantName      String?
  productUrl        String?
  affiliateUrl      String
  currentPrice      Decimal?          @db.Decimal(10, 2)
  oldPrice          Decimal?          @db.Decimal(10, 2)
  currency          String            @default("EUR")
  couponCode        String?
  couponDescription String?
  shippingCost      Decimal?          @db.Decimal(10, 2)
  availability      OfferAvailability @default(UNKNOWN)
  validFrom         DateTime?
  validUntil        DateTime?
  lastCheckedAt     DateTime?
  manuallyVerified  Boolean           @default(false)
  sponsored         Boolean           @default(false)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tool         Tool             @relation(fields: [toolId], references: [id], onDelete: Cascade)
  partner      AffiliatePartner @relation(fields: [partnerId], references: [id])
  priceHistory PriceHistory[]
  deals        Deal[]

  @@index([toolId])
  @@index([partnerId])
  @@map("product_offers")
}

model PriceHistory {
  id           String            @id @default(cuid())
  offerId      String
  toolId       String?
  partnerId    String?
  price        Decimal?          @db.Decimal(10, 2)
  oldPrice     Decimal?          @db.Decimal(10, 2)
  currency     String            @default("EUR")
  availability OfferAvailability @default(UNKNOWN)
  checkedAt    DateTime          @default(now())

  offer ProductOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId, checkedAt])
  @@map("price_history")
}

// -----------------------------------------------------------------
// Varel Price Checker: server-side cache for Amazon PA-API searches.
// Optional — the tool degrades gracefully if this table is unavailable.
// -----------------------------------------------------------------
model PriceCheckerCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  payload   Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("price_checker_cache")
}

// -----------------------------------------------------------------
// Varel LLM Visibility Scanner — lead + scan request.
// Deterministic scanner (no LLM API). Scan results + generated report
// are stored as JSON to keep the model lean.
// -----------------------------------------------------------------
model LlmScanRequest {
  id                String  @id @default(cuid())
  websiteUrl        String
  normalizedDomain  String
  email             String
  name              String?
  companyName       String?
  preferredLanguage String  @default("en")

  permissionConfirmed   Boolean   @default(false)
  permissionConfirmedAt DateTime?
  permissionIp          String?

  freeScanCompleted Boolean @default(false)
  freeScanScore     Int?
  freeScanJson      Json?

  detailedReportRequested Boolean @default(false)
  pageSelectionMethod     String?
  additionalUrlsJson      Json?

  socialProfileAddon    Boolean @default(false)
  socialProfileUrlsJson Json?
  competitorAddon       Boolean @default(false)
  competitorUrl         String?

  basePrice  Int @default(20)
  addonPrice Int @default(0)
  totalPrice Int @default(20)

  paymentMethod String @default("manual_offer")
  paymentStatus String @default("not_sent")
  reportStatus  String @default("lead_created")

  finalReportApprovedByAdmin Boolean   @default(false)
  approvedByAdminAt          DateTime?

  privateReportToken String? @unique
  publicShareSlug    String? @unique
  publicShareEnabled Boolean @default(false)

  reportJson Json?
  adminNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportStatus])
  @@index([email])
  @@map("llm_scan_requests")
}

// =================================================================
// Varel HVAC — B2B multi-tenant SaaS (Croatian MVP).
// Every tenant-owned record carries `tenantId` (indexed). Tenant
// isolation is enforced server-side in the data layer, never by the
// client. Money is Decimal(10,2). Auth users (HvacUser) are separate
// from the admin `User` table.
// =================================================================

enum HvacPlan {
  START
  TEAM
  BUSINESS
}

enum HvacContractTerm {
  MONTHLY
  ANNUAL12
  ANNUAL24
}

enum HvacTenantStatus {
  TRIAL
  PENDING_ACTIVATION
  ACTIVE
  OVERDUE
  SUSPENDED
  CANCELLED
}

enum HvacRole {
  OWNER
  ADMINISTRATOR
  DISPATCHER
  TECHNICIAN
  ACCOUNTANT
}

enum HvacEmploymentType {
  EMPLOYEE
  EXTERNAL
  TEMPORARY
}

enum HvacCustomerType {
  INDIVIDUAL
  COMPANY
}

enum HvacUnitType {
  SPLIT
  MULTI_SPLIT
  PORTABLE
  CASSETTE
  DUCTED
  FLOOR
  ROOFTOP
  HEAT_PUMP
  OTHER
}

enum HvacUnitStatus {
  ACTIVE
  TEMPORARILY_INACTIVE
  REMOVED
  REPLACED
  UNDER_REPAIR
  ARCHIVED
}

enum HvacInquiryStatus {
  NEW
  CONTACTED
  WAITING_INFO
  WAITING_APPOINTMENT
  SCHEDULED
  REJECTED
  CLOSED
}

enum HvacAppointmentStatus {
  NEW_INQUIRY
  WAITING_CONFIRMATION
  CONFIRMED
  TECH_ASSIGNED
  TECH_EN_ROUTE
  IN_PROGRESS
  COMPLETED
  WAITING_PARTS
  POSTPONED
  CANCELLED
  NO_SHOW
}

enum HvacPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum HvacWorkOrderStatus {
  DRAFT
  SCHEDULED
  EN_ROUTE
  IN_PROGRESS
  PAUSED
  WAITING_PARTS
  COMPLETED
  SENT
  CANCELLED
}

enum HvacQuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED_WORKORDER
  CONVERTED_INVOICE
}

enum HvacInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum HvacPaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  OTHER
}

enum HvacReminderStatus {
  FUTURE
  UPCOMING
  READY
  CONTACTED
  BOOKED
  POSTPONED
  REJECTED
  COMPLETED
}

enum HvacSource {
  HOSTED_BOOKING
  PHONE
  EMAIL
  WEBSITE
  SOCIAL
  RECOMMENDATION
  EXISTING_CUSTOMER
  MANUAL
  OTHER
}

enum HvacWorkOrderItemKind {
  LABOR
  MATERIAL
  PART
}

enum HvacDocType {
  WORK_ORDER
  QUOTATION
  INVOICE
}

model HvacTenant {
  id                  String           @id @default(cuid())
  name                String
  slug                String           @unique
  oib                 String?
  legalForm           String?
  address             String?
  city                String?
  postalCode          String?
  phone               String?
  email               String?
  website             String?
  logoUrl             String?
  documentFooter      String?          @db.Text
  vatRegistered       Boolean          @default(false)
  plan                HvacPlan         @default(START)
  status              HvacTenantStatus @default(TRIAL)
  onboardingStep      Int              @default(0)
  onboardingCompleted Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  deletedAt           DateTime?

  settings      HvacTenantSettings?
  bookingSettings HvacBookingSettings?
  subscription  HvacSubscription?
  members       HvacTenantUser[]

  @@index([status])
  @@map("hvac_tenants")
}

model HvacTenantSettings {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  workingHoursJson Json?
  blockedDatesJson Json?
  invoiceVatRate  Decimal  @default(25) @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant HvacTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("hvac_tenant_settings")
}

model HvacSubscription {
  id                   String           @id @default(cuid())
  tenantId             String           @unique
  plan                 HvacPlan         @default(START)
  // Packages are monthly with no long-term contract; kept for future flexibility.
  term                 HvacContractTerm @default(MONTHLY)
  monthlyPriceEur      Decimal          @db.Decimal(10, 2)
  includedUsers        Int              @default(1)
  additionalUsers      Int              @default(0)
  status               HvacTenantStatus @default(TRIAL)
  startDate            DateTime?
  endDate              DateTime?
  trialEndsAt          DateTime?
  billingNotes         String?          @db.Text
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  tenant HvacTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("hvac_subscriptions")
}

// Auth identity for B2B users — separate from the admin `User` table.
model HvacUser {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String
  phone             String?
  emailVerifiedAt   DateTime?
  verifyToken       String?   @unique
  resetToken        String?   @unique
  resetTokenExpires DateTime?
  isActive          Boolean   @default(true)
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  memberships HvacTenantUser[]

  @@map("hvac_users")
}

// Tenant membership + role (a user can belong to multiple tenants).
model HvacTenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
