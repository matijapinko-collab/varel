  comparisonId   String
  label          String
  toolValuesJson Json?
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  comparison Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)

  @@map("comparison_rows")
}

// -----------------------------------------------------------------
// Prompt library
