  compatibleModelsJson Json?
  status               ContentStatus @default(DRAFT)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  prompt   Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
