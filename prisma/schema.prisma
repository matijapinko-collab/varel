// Version manager & backups
// -----------------------------------------------------------------

model AppVersion {
  id          String        @id @default(cuid())
  version     String        @unique
  title       String
  changelog   String?       @db.Text
  status      VersionStatus @default(DRAFT)
  createdById String?
  createdAt   DateTime      @default(now())
  appliedAt   DateTime?

  createdBy User?           @relation(fields: [createdById], references: [id])
  packages  UpdatePackage[]

  @@map("app_versions")
}

model UpdatePackage {
  id               String   @id @default(cuid())
  versionId        String
  codePatch        String?  @db.Text
  migrationPatch   String?  @db.Text
  configPatch      String?  @db.Text
  validationStatus String?
  testStatus       String?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  version AppVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@map("update_packages")
}

model Backup {
  id          String       @id @default(cuid())
  type        BackupType   @default(MANUAL)
  status      BackupStatus @default(PENDING)
  storageUrl  String?
  size        Int?
