model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  valueJson   Json?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model BrandingSetting {
  id                String    @id @default(cuid())
  siteName          String    @default("Varel")
  tagline           String?
  lightLogoId       String?
  darkLogoId        String?
  faviconId         String?
  appIconId         String?
  defaultOgImageId  String?
  primaryColor      String    @default("#2563EB")
  accentColor       String    @default("#0EA5E9")
  defaultTheme      ThemeMode @default(LIGHT)
  enableThemeToggle Boolean   @default(true)
  fontFamily        String    @default("Inter")
  borderRadius      String    @default("0.75rem")
  buttonStyle       String    @default("rounded")
  socialLinksJson   Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("branding_settings")
}

model Menu {
  id         String       @id @default(cuid())
  name       String
  location   MenuLocation
  languageId String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  language Language   @relation(fields: [languageId], references: [id])
  items    MenuItem[]

  @@unique([location, languageId])
  @@map("menus")
}

model MenuItem {
  id           String   @id @default(cuid())
  menuId       String
  parentItemId String?
  label        String
  url          String
  entityType   String?
  entityId     String?
  position     Int      @default(0)
  isExternal   Boolean  @default(false)
  openInNewTab Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parentItem MenuItem?  @relation("MenuItemHierarchy", fields: [parentItemId], references: [id])
  childItems MenuItem[] @relation("MenuItemHierarchy")

  @@index([menuId, position])
  @@map("menu_items")
}

// -----------------------------------------------------------------
