// =============================================================
// BISNEYS CRM
// Isolated internal CRM (sales + recruitment ATS + Trello analytics).
// Every model is prefixed `Bisneys*` and mapped to a `bisneys_*` table so
// it never collides with, or couples to, the existing Varel models.
// Domain models are Trello-independent (adapter pattern):
//   TrelloCard --> sync/mapping --> BisneysCompany | BisneysCandidate | BisneysJob
// so the whole CRM can outlive the Trello integration.
// =============================================================

enum BisneysRole {
  SUPERADMIN
  ADMIN
}

enum BisneysActivitySource {
  TRELLO
  BISNEYS_CRM
  SYSTEM
  IMPORT
}

enum BisneysActivityType {
  COMPANY_CREATED
  COMPANY_UPDATED
  LEAD_CREATED
  LEAD_UPDATED
  CALL_LOGGED
  COMMENT_ADDED
  FOLLOW_UP_CREATED
  FOLLOW_UP_COMPLETED
  PITCH_SENT
  PITCH_PRESENTED
  MEETING_SCHEDULED
  MEETING_COMPLETED
  DEAL_VALUE_CHANGED
  DEAL_WON
  DEAL_LOST
  CARD_MOVED
  CONTACT_ADDED
  DUE_DATE_CHANGED
  DOCUMENT_UPLOADED
  CANDIDATE_CREATED
  CANDIDATE_UPDATED
  CANDIDATE_STATUS_CHANGED
  RELATIONSHIP_ADDED
  RELATIONSHIP_REMOVED
}

enum BisneysSyncStatus {
  PENDING
  SYNCING
  SYNCED
  PARTIALLY_SYNCED
  ERROR
  DISCONNECTED
}

enum BisneysSalesStatus {
  INTERNAL_GUIDELINES
  NEW_COMPANY
  RESEARCH
  NEW_LEAD
  QUALIFICATION
  FOLLOW_UP
  PITCH
  MEETING
  NURTURE
  NEGOTIATE
  CLOSED
  LOST
  ARCHIVED
  ON_HOLD
}

enum BisneysCandidateStatus {
  NEW
  CONTACTED
  FIRST_CALL
  QUALIFIED
  SECOND_INTERVIEW
  READY_FOR_CLIENT
  SENT_TO_CLIENT
  CLIENT_INTERVIEW
  CLIENT_INTERESTED
  OFFERED
  HIRED
  REJECTED
  CANDIDATE_DECLINED
  ON_HOLD
  UNREACHABLE
}

enum BisneysDealStatus {
  OPEN
  WON
  LOST
}

enum BisneysCallOutcome {
  ANSWERED
  NO_ANSWER
  CALL_BACK
  INTERESTED
  NOT_INTERESTED
  MEETING_BOOKED
  WRONG_NUMBER
  UNREACHABLE
}

enum BisneysMeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum BisneysNotificationStatus {
  UNREAD
  READ
  RESOLVED
  DISMISSED
}

enum BisneysNotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BisneysRelationshipDirection {
  DIRECTED
  SYMMETRIC
}

// ---------------- Auth & system ----------------

model BisneysUser {
  id                 String       @id @default(cuid())
  username           String       @unique
  email              String       @unique
  passwordHash       String
  role               BisneysRole  @default(ADMIN)
  isActive           Boolean      @default(true)
  mustChangePassword Boolean      @default(true)
  // Bumped on password change / "log out everywhere" → invalidates old sessions.
  sessionVersion     Int          @default(0)
  lastLoginAt        DateTime?
  passwordChangedAt  DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  auditLogs BisneysAuditLog[]

  @@map("bisneys_users")
}

model BisneysAuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  ipHash     String?
  userAgent  String?
  source     String?
  requestId  String?
  createdAt  DateTime @default(now())

  user BisneysUser? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@map("bisneys_audit_logs")
}

model BisneysSetting {
  key       String   @id
  valueJson Json?
  updatedAt DateTime @updatedAt

  @@map("bisneys_settings")
}

// ---------------- People, companies, contacts ----------------

model BisneysPerson {
  id          String    @id @default(cuid())
  firstName   String?
  lastName    String?
  fullName    String
  email       String?
  phone       String?
  phone2      String?
  country     String?
  city        String?
  address     String?
  dateOfBirth DateTime?
  citizenship String?
  notes       String?
  source      String?
  // Normalized contact for dedup + search (brief §7/§43).
  normalizedEmail String?
  normalizedPhone String?
  // Relationship Intelligence Engine fields.
  secondaryEmail String?
  secondaryPhone String?
  linkedinUrl    String?
  avatarUrl      String?
  headline       String?
  isVerified     Boolean @default(false)
  verificationStatus String? @default("UNVERIFIED")
  networkScore   Int?
  referralScore  Int?
  updatedById String?
  lastActivityAt DateTime?
  // Trello linkage (a person may originate from a card / member).
  externalId    String?
  externalSource String?
  lastSyncedAt   DateTime?
  syncStatus     BisneysSyncStatus?
  rawData        Json?
  createdById String?
  deletedAt   DateTime?
  deletedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roles              BisneysPersonRole[]
  companyMemberships BisneysCompanyMembership[]
  contacts           BisneysContact[]
  candidate          BisneysCandidate?
  employments        BisneysEmployment[]
  relationsFrom      BisneysRelationship[]      @relation("BisneysRelFrom")
  relationsTo        BisneysRelationship[]      @relation("BisneysRelTo")
  referralsGiven     BisneysReferral[]          @relation("BisneysReferrer")
  referralsGot       BisneysReferral[]          @relation("BisneysReferred")
  trelloMember       BisneysTrelloMember?

  @@index([fullName])
  @@index([email])
  @@index([phone])
  @@index([normalizedEmail])
  @@index([normalizedPhone])
  @@index([linkedinUrl])
  @@map("bisneys_people")
}

model BisneysPersonRole {
