  CLIENT_INTERVIEW
  OFFERED
  HIRED
  REJECTED_BY_CLIENT
  PLACEMENT
  POTENTIAL_CONTACT
}

/**
 * An explicit, typed relation between a candidate and a company (Faza 5). A
 * candidate can hold several relations with the same company (e.g. former
 * employee AND sent-to-client). Employment/application/referral history stays
 * in its own models; the company "Kandidati" view aggregates all of them.
 */
model BisneysCandidateCompanyLink {
  id          String                     @id @default(cuid())
  candidateId String
  companyId   String
  relation    BisneysCompanyRelationType
  jobId       String?
  note        String?
  fee         Decimal?                   @db.Decimal(12, 2)
  eventAt     DateTime?
  createdById String?
  createdAt   DateTime                   @default(now())
  deletedAt   DateTime?

  candidate BisneysCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company   BisneysCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([candidateId])
  @@index([relation])
  @@map("bisneys_candidate_company_links")
}
