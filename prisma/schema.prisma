  @@unique([promptId, languageId])
  @@unique([languageId, slug])
  @@map("prompt_translations")
}

// -----------------------------------------------------------------
// Deals
// -----------------------------------------------------------------

model Deal {
  id              String        @id @default(cuid())
  brandName       String
  affiliateLinkId String?
  imageId         String?
  // Best Deals module: a deal can be tied to a catalogue product (Tool), a
  // specific ProductOffer and the affiliate partner behind it.
  productId       String?
  offerId         String?
  partnerId       String?
  oldPrice        Decimal?      @db.Decimal(10, 2)
  newPrice        Decimal?      @db.Decimal(10, 2)
  currency        String        @default("EUR")
  discountPercent Int?
  isFeatured      Boolean       @default(false)
  startsAt        DateTime?
  validUntil      DateTime?
  endsAt          DateTime?
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  affiliateLink AffiliateLink?    @relation(fields: [affiliateLinkId], references: [id])
  image         Media?            @relation("DealImage", fields: [imageId], references: [id])
  product       Tool?             @relation("DealProduct", fields: [productId], references: [id])
  offer         ProductOffer?     @relation(fields: [offerId], references: [id])
  partner       AffiliatePartner? @relation(fields: [partnerId], references: [id])
  translations  DealTranslation[]

  @@index([status])
  @@index([isFeatured])
  @@map("deals")
}

model DealTranslation {
  id          String        @id @default(cuid())
  dealId      String
  languageId  String
  title       String
  slug        String
  description String?       @db.Text
  ctaText     String?
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  deal     Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id])

  @@unique([dealId, languageId])
  @@unique([languageId, slug])
  @@map("deal_translations")
}

// -----------------------------------------------------------------
// Affiliate manager
// -----------------------------------------------------------------

model AffiliateLink {
  id                   String              @id @default(cuid())
  brandName            String
  entityType           AffiliateEntityType @default(CUSTOM)
  toolId               String?
  originalUrl          String?
  affiliateUrl         String
  network              AffiliateNetwork    @default(DIRECT)
  commissionType       String?
  commissionValue      String?
  cookieDurationDays   Int?
  allowedCountriesJson Json?
  status               AffiliateStatus     @default(ACTIVE)
  notes                String?             @db.Text
  lastCheckedAt        DateTime?
  deletedAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  tool         Tool?                  @relation(fields: [toolId], references: [id])
  clicks       AffiliateClick[]
  deals        Deal[]
  articleLinks ArticleAffiliateLink[]

  @@index([status])
  @@map("affiliate_links")
}

model AffiliateClick {
  id               String   @id @default(cuid())
  affiliateLinkId  String
  sourceEntityType String?
  sourceEntityId   String?
  languageCode     String?
  country          String?
  device           String?
  referrer         String?
  userAgent        String?
  ipHash           String?
  clickedAt        DateTime @default(now())

  affiliateLink AffiliateLink @relation(fields: [affiliateLinkId], references: [id], onDelete: Cascade)

  @@index([affiliateLinkId, clickedAt])
  @@map("affiliate_clicks")
}

// -----------------------------------------------------------------
// Analytics
// -----------------------------------------------------------------

model AnalyticsEvent {
  id           String             @id @default(cuid())
  type         AnalyticsEventType
  entityType   String?
  entityId     String?
  languageCode String?
  path         String?
  country      String?
